rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if true;
    }
    match /matches/{matchId} {
      allow read, write: if true;
      match /participants/{partId} {
        allow read, write: if true;
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
